{
  "name": "pronunciation-vault",
  "version": "0.1.8",
  "description": "Local pronunciation vocabulary tool for language learning.",
  "main": "dist-electron/electron/main.js",
  "author": "danlyh5288",
  "private": true,
  "workspaces": [
    "mobile",
    "functions"
  ],
  "overrides": {
    "js-yaml": "^4.2.0",
    "uuid": "^11.1.1"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:renderer": "vite --host 127.0.0.1",
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.node.json && vite build",
    "dist:mac": "npm run build && electron-builder --mac dmg",
    "dist:mac:bump": "node scripts/bump-version.mjs $npm_config_release && npm run dist:mac",
    "mobile:dev": "npm run start --workspace @pronunciation-vault/mobile",
    "mobile:ios": "npm run ios --workspace @pronunciation-vault/mobile",
    "mobile:android": "npm run android --workspace @pronunciation-vault/mobile",
    "mobile:typecheck": "npm run typecheck --workspace @pronunciation-vault/mobile",
    "mobile:test": "npm run test --workspace @pronunciation-vault/mobile",
    "functions:build": "npm run build --workspace @pronunciation-vault/functions",
    "preview": "vite preview --host 127.0.0.1",
    "test:firebase:rules": "firebase emulators:exec --only firestore,storage \"vitest --run --config firebase/vitest.config.ts\"",
    "test": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "version:bump": "node scripts/bump-version.mjs $npm_config_release"
  },
  "build": {
    "appId": "com.local.pronunciationvault",
    "productName": "发音词库",
    "copyright": "Copyright © 2026",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.education",
      "icon": "build/icon.icns",
      "identity": null,
      "target": "dmg"
    },
    "dmg": {
      "artifactName": "FaYinCiKu-${version}-${arch}.${ext}",
      "title": "发音词库 ${version}",
      "contents": [
        {
          "x": 150,
          "y": 170,
          "type": "file"
        },
        {
          "x": 390,
          "y": 170,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 540,
        "height": 360
      }
    }
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-select": "^2.3.1",
    "firebase": "^12.15.0",
    "lucide-react": "^0.468.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "sql.js": "^1.13.0"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/sql.js": "^1.4.9",
    "@vitejs/plugin-react": "^6.0.2",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "jsdom": "^29.1.1",
    "typescript": "^5.7.2",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
