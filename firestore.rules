rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function owns(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function canUseCloudSync(userId) {
      return owns(userId);
    }

    function userShellKeys() {
      return ["libraryInitialized", "updatedAt"];
    }

    function tagKeys() {
      return ["name", "color", "createdAt", "updatedAt", "deletedAt"];
    }

    function wordKeys() {
      return ["text", "tagId", "toneNote", "recording", "createdAt", "updatedAt", "deletedAt"];
    }

    match /users/{userId} {
      allow read: if owns(userId);
      allow create, update: if canUseCloudSync(userId) &&
        request.resource.data.keys().hasOnly(userShellKeys());
      allow delete: if false;

      match /entitlements/{entitlementId} {
        allow read: if owns(userId);
        allow write: if false;
      }

      match /tags/{tagId} {
        allow read: if canUseCloudSync(userId);
        allow create, update: if canUseCloudSync(userId) &&
          request.resource.data.keys().hasOnly(tagKeys()) &&
          request.resource.data.name is string &&
          request.resource.data.color is string;
        allow delete: if false;
      }

      match /words/{wordId} {
        allow read: if canUseCloudSync(userId);
        allow create, update: if canUseCloudSync(userId) &&
          request.resource.data.keys().hasOnly(wordKeys()) &&
          request.resource.data.text is string &&
          request.resource.data.toneNote is string;
        allow delete: if false;
      }
    }
  }
}
